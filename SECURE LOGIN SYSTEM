# --- ROUTE HANDLING ENGINES ---

@app.route('/')
def home():
    html_content = '<h2>Home Gateway</h2>Welcome! Please <a href="/login">Login</a> or <a href="/register">Register</a>.'
    return render_template_string(BASE_LAYOUT, content=html_content)

@app.route('/register', methods=['GET', 'POST'])
def register():
    if request.method == 'POST':
        email = request.form.get('email', '').strip().lower()
        password = request.form.get('password', '')

        # Server-Side Robust Validation Sanitization
        try:
            validate_email(email)
        except EmailNotValidError:
            flash('Invalid email structural format.', 'danger')
            return redirect(url_for('register'))

        if len(password) < 8:
            flash('Password complexity error: Must be at least 8 characters.', 'danger')
            return redirect(url_for('register'))

        if User.query.filter_by(email=email).first():
            flash('Security Notice: Email system registry conflict.', 'danger')
            return redirect(url_for('register'))

        # Secure Hashing via Argon2id
        hashed_password = ph.hash(password)
        new_user = User(email=email, password_hash=hashed_password)
        db.session.add(new_user)
        db.session.commit()

        flash('Registration successful! Secure hash generated. Please log in.', 'success')
        return redirect(url_for('login'))

    form_html = '''
        <h2>Account Creation</h2>
        <form method="POST">
            <input type="email" name="email" placeholder="Enter Registration Email" required><br>
            <input type="password" name="password" placeholder="Set Secure Password" required><br>
            <button type="submit">Register Account</button>
        </form>
        <p style="margin-top:15px;">Existing user? <a href="/login">Login here</a></p>
    '''
    return render_template_string(BASE_LAYOUT, content=form_html)

@app.route('/login', methods=['GET', 'POST'])
def login():
    if request.method == 'POST':
        email = request.form.get('email', '').strip().lower()
        password = request.form.get('password', '')

        user = User.query.filter_by(email=email).first()
        
        # Mitigation for User Enumeration: Vague, identical fallback errors
        generic_error = "Access Denied: Invalid email or password credentials."
        
        if not user:
            flash(generic_error, 'danger')
            return redirect(url_for('login'))

        try:
            # Verification computations
            ph.verify(user.password_hash, password)
            login_user(user) # Saves context state and implicitly rotates session token identifiers
            return redirect(url_for('dashboard'))
        except VerifyMismatchError:
            flash(generic_error, 'danger')
            return redirect(url_for('login'))

    form_html = '''
        <h2>Secure Gateway Login</h2>
        <form method="POST">
            <input type="email" name="email" placeholder="Account Email Address" required><br>
            <input type="password" name="password" placeholder="Account Password" required><br>
            <button type="submit" style="background:#007BFF;">Authenticate</button>
        </form>
        <p style="margin-top:15px;">New entity? <a href="/register">Create an account</a></p>
    '''
    return render_template_string(BASE_LAYOUT, content=form_html)

@app.route('/dashboard')
@login_required # Active session requirement layer protection
def dashboard():
    html_content = f'''
        <h2>Secure User Workspace</h2>
        <p>Authenticated Identity: <strong>{current_user.email}</strong></p>
        <p>This perimeter is protected by cryptographic authorization cookies.</p>
        <br><a href="/logout" style="color: #dc3545; font-weight:bold;">Terminate Session (Logout)</a>
    '''
    return render_template_string(BASE_LAYOUT, content=html_content)

@app.route('/logout')
@login_required
def logout():
    logout_user() # Drops backend state tracking maps and signals browser tracking clears
    flash('Session terminated successfully.', 'success')
    return redirect(url_for('login'))

if __name__ == '__main__':
    with app.app_context():
        db.create_all() # Automatically maps local structural file sqlite DB
    app.run(host='127.0.0.1', port=5000, debug=True)
